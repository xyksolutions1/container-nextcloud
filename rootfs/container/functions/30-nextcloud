nextcloud_bootstrap_webroot() {
    installed_version="0.0.0~unknown"
    create_folder "${NGINX_WEBROOT}" "${NGINX_USER}":"${NGINX_GROUP}" 750
    silent rsync -a --delete --exclude /config/ --exclude /data/ --exclude /custom-apps/ --exclude /themes/ /container/data/nextcloud/install/ "${NGINX_WEBROOT%/}"/
    create_folder \
                    "${NGINX_WEBROOT%/}/config,\
                    ${NGINX_WEBROOT%/}/custom-apps,\
                    ${NGINX_WEBROOT%/}/data,\
                    ${NGINX_WEBROOT%/}/themes" \
                    "${NGINX_USER}":"${NGINX_GROUP}" 750

    #chown -R "${NGINX_USER}":"${NGINX_GROUP}" "${NGINX_WEBROOT}"

    for dir in config themes; do
        if dir_empty "${NGINX_WEBROOT%/}"/"${dir}"; then
            silent cp -arT /container/data/nextcloud/install/"$dir" "${NGINX_WEBROOT%/}"/"${dir}"
        fi
    done

    if [ "${APP_PATH%/}" != "${NGINX_WEBROOT}/custom-apps}" ]; then
        rm -rf "${NGINX_WEBROOT%/}"/custom-apps
        ln -sf "${APP_PATH}" "${NGINX_WEBROOT%/}"/custom-apps
    fi

    if dir_empty "${APP_PATH}"; then
        silent cp -arT /container/data/nextcloud/install/custom-apps "${APP_PATH}"
    fi
}

nextcloud_check_databases() {
    case "${DB_TYPE,,}" in
    "mysql" | "mariadb")
        DB_PORT=${DB_PORT:-3306}
        sanity_db mariadb
        db_ready mariadb
        install_options="--database=mysql --database-host=${DB_HOST} --database-name=${DB_NAME} --database-user=${DB_USER} --database-pass=${DB_PASS} --database-table-space=${DB_PREFIX} --database-port=${DB_PORT}"
        ;;
    sqlite*)
        DB_TYPE="sqlite3"
        install_options="--database-name $SQLITE_DATABASE"
        ;;
    postgres*)
        DB_PORT=${DB_PORT:-5432}
        sanity_db
        db_ready postgres
        install_options="--database=pgsql --database-host=${DB_HOST} --database-name=${DB_NAME} --database-user=${DB_USER} --database-pass=${DB_PASS} --database-table-space=${DB_PREFIX} --database-port=${DB_PORT}"
        ;;
    *)
        print_error "Unknown DB_TYPE Variable - Exiting"
        exit 1
        ;;
    esac
}

nextcloud_configure_application_settings() {
    ngo() {
        local cf="${1}"
        local ev="${2}"
        local opt="${3}"
        local nv="${4}"

        if [ -n "${!ev}" ]; then
            return 0
        fi

        if [ ! -f "${cf}" ]; then
            return 1
        fi

        local cv=$(grep -oP "^\s*${opt}\s+\K[^;]+" "${cf}" | head -1)

        if [ -z "${cv}" ]; then
            return 1
        fi

        if [ "${cv}" != "${nv}" ]; then
            print_debug "[ngo] Updating '${opt}' from '${cv}' to '${nv}' in ${cf}"
            sed -i "s|^\(\s*${opt}\s\+\)[^;]\+;|\1${nv};|" "${cf}"
        fi
    }

    ngo /etc/nginx/nginx.conf NGINX_CLIENT_BODY_TIMEOUT client_body_timeout 300s
    ngo /etc/nginx/nginx.conf NGINX_CLIENT_BODY_BUFFER_SIZE client_body_buffer_size 512k
    ngo /etc/nginx/nginx.conf NGINX_FASTCGI_BUFFERS fastcgi_buffers "64 4k"
    ngo /etc/nginx/nginx.conf NGINX_KEEP_ALIVE_TIMEOUT keepalive_timeout 600
    ngo /etc/nginx/nginx.conf NGINX_SEND_TIMEOUT send_timeout 600

    if var_false "${CONTAINER_ENABLE_SCHEDULING}"; then
        silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT}"/occ background:ajax
    else
        echo "*/${CRON_PERIOD} * * * * sudo -u ${NGINX_USER} TZ=${TIMEZONE} php -d memory_limit=${PHP_MEMORY_LIMIT} -f ${NGINX_WEBROOT}/cron.php >/dev/null 2>&1"  | silent tee /container/cron/nextcloud
        silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT}"/occ background:cron
    fi

    silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ config:app:set admin_audit logfile --value="${LOG_PATH%/}"/"${LOG_FILE_AUDIT}"

    local tindex=1
    trusted_domains=$(echo "${TRUSTED_DOMAINS}" | tr "," "\n")
    for domain in ${trusted_domains}; do
        domain=$(echo "$domain" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
        silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ config:system:set trusted_domains $tindex --value="${domain}"
        ((tindex += 1))
    done

    silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ config:system:set trusted_proxies 0 --value="127.0.0.1"
    tindex=1
    trusted_proxies=$(echo "${TRUSTED_PROXIES}" | tr "," "\n")
    for proxy in ${trusted_proxies}; do
        silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ config:system:set trusted_proxies $tindex --value="${proxy}"
        ((tindex += 1))
    done

    if [ -n "${IFRAME_DOMAINS}" ]; then
        iframe_domains=$(echo "${IFRAME_DOMAINS}" | tr "," "\n")
        for iframe_domain in ${iframe_domains}; do
            print_debug "Adding '${iframe_domain}' as a source to be able to load iframes"
            sed -i "/protected \$allowedFrameAncestors = \[/a\ \ \ \ \ \ \ \ \ \ \ \ \ \ \ \ \'${iframe_domain}\'," "${NGINX_WEBROOT}"/lib/public/AppFramework/Http/ContentSecurityPolicy.php
        done
    fi

    if [ -n "${MONITORING_APPLICATION_TOKEN}" ]; then
        if sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ app:list 2 &>1 | sed '/Disabled:/q' | grep -qo 'serverinfo'; then
            print_debug "Setting Application Token for Server Info Application"
            silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ config:app:set serverinfo token --value "${MONITORING_APPLICATION_TOKEN}"
        fi
    fi

    if [ -n "${ADMIN_MEMBERS}" ]; then
        admin_users=$(echo "${ADMIN_MEMBERS}" | tr "," "\n")
        for admin_user in $admin_users; do
            silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ group:adduser admin $admin_user
            print_warn "Added '${admin_user}' to admin group"
        done
    fi

    if [ -n "${ADMIN_PASS}" ] && [ -n "${ADMIN_USER}" ]; then
        export OC_PASS="${ADMIN_PASS}"
        print_debug "Resetting Admin Password"
        silent sudo --preserve-env=OC_PASS -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ user:resetpassword --password-from-env ${ADMIN_USER}
    fi

    if var_true "${ENABLE_FILES_BACKEND}"; then
        print_debug "Enabling Hi Performance Files Backend"
        if var_true "${fbproceed}"; then
            update_template \${}
                                FILES_BACKEND_PROTOCOL \
                                FILES_BACKEND_HOST \
                                FILES_BACKEND_PORT \
                            /etc/nginx/sites.available/files_backend.snippet
        else
            rm -rf /etc/services.available/30-nextcloud
            sed -i "/include \/etc\/nginx\/sites.available\/files_backend.snippet;/d" /etc/nginx/sites.available/nextcloud.conf
        fi
    else
        print_debug "Disabling Hi Performance Files Backend"
        rm -rf /etc/services.available/30-nextcloud
        sed -i "/include \/etc\/nginx\/sites.available\/files_backend.snippet;/d" /etc/nginx/sites.available/nextcloud.conf
    fi

    cat <<EOF | silent tee -a /root/.bashrc
occ() {
      export oldpwd="\$(pwd)"
      cd ${NGINX_WEBROOT}
      sudo -u ${NGINX_USER} php occ "\$@"
      cd "\${oldpwd}"
}
EOF
}

nextcloud_configure_logging() {
    create_folder "${LOG_PATH}" "${NGINX_USER}":"${NGINX_GROUP}" 755
    sudo -u "${NGINX_USER}" touch "${LOG_PATH%/}"/"${LOG_FILE}"
    sudo -u "${NGINX_USER}" touch "${LOG_PATH%/}"/"${LOG_FILE_AUDIT}"
    sudo -u "${NGINX_USER}" touch "${LOG_PATH%/}"/"${LOG_FILE_FLOW}"
    create_logrotate nextcloud "${LOG_PATH%/}"/"${LOG_FILE}" nextcloud "${NGINX_USER}" "${NGINX_GROUP}"
    create_logrotate nextcloud-audit "${LOG_PATH%/}"/"${LOG_FILE_AUDIT}" none "${NGINX_USER}" "${NGINX_GROUP}"
    create_logrotate nextcloud-flow "${LOG_PATH%/}"/"${LOG_FILE_FLOW}" none "${NGINX_USER}" "${NGINX_GROUP}"
}

nextcloud_configure_fail2ban() {
    source /container/defaults/07-firewall
	print_debug "Fail2Ban: Adding Jail - Nextcloud"
	cat <<EOF >> "${FAIL2BAN_CONFIG_PATH%/}"/jail.d/nextcloud.conf
[nextcloud]
backend = auto
enabled = true
port = 80,443
protocol = tcp
filter = nextcloud
maxretry = ${FAIL2BAN_MAX_RETRY}
bantime = ${FAIL2BAN_TIME_BAN}
findtime = ${FAIL2BAN_TIME_FIND}
logpath = ${LOG_PATH%/}/${LOG_FILE}
EOF
}

