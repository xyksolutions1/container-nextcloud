nextcloud_install_application() {
    set -x
    if [ -f "${USERDATA_PATH%/}/.version" ]; then
        installed_version=$(head -n 1 "${USERDATA_PATH%/}"/.version | awk '{print $1}')
    else
        echo "${NEXTCLOUD_VERSION} migrated from existing install on $(TZ=${TIMEZONE} date +'%Y-%m-%d %H:%M:%S %Z')" | silent tee -a "${USERDATA_PATH%/}"/.version
    fi

    if version_greater "$installed_version" "${NEXTCLOUD_VERSION}"; then
        print_error "Can't start Nextcloud because the version of the data ($installed_version) is higher than the docker image version (${NEXTCLOUD_VERSION}) and downgrading is not supported. Are you sure you have pulled the newest image version?"
        exit 1
    fi

    if var_true "${ENABLE_AUTO_UPGRADE}"; then
        if version_greater "${NEXTCLOUD_VERSION}" "$installed_version"; then
            if [ "${installed_version}" != "0.0.0~unknown" ]; then
                silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ app:list | tee /tmp/nextcloud_applist_pre
                silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ upgrade
                silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ db:add-missing-indices
                silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT%/}"/occ app:list  | tee /tmp/nextcloud_applist_post
                print_warn "The following apps have been disabled:"
                diff <(sed -n "/Enabled:/,/Disabled:/p" /tmp/nextcloud_applist_pre) <(sed -n "/Enabled:/,/Disabled:/p" /tmp/nextcloud_applist_post) | grep '<' | cut -d- -f2 | cut -d: -f1
                diff <(sed -n "/Enabled:/,/Disabled:/p" /tmp/nextcloud_applist_pre) <(sed -n "/Enabled:/,/Disabled:/p" /tmp/nextcloud_applist_post) | grep '<' | cut -d- -f2 | cut -d: -f1 | silent tee -a ${USERDATA_PATH}/.version
                echo "${NEXTCLOUD_VERSION} automatically upgraded on $(TZ=${TIMEZONE} date +'%Y-%m-%d %H:%M:%S %Z')" | cat - "${USERDATA_PATH$/}"/.version >/tmp/.version && mv /tmp/.version "${USERDATA_PATH$/}"/.version
                rm -f /tmp/nextcloud_applist_{pre,post}
            fi
        fi
    fi

    set +x
    if [ ! -f "${NGINX_WEBROOT}"/config/config.php ]; then
        print_warn "New Installation Detected"

        sanity_var ADMIN_USER "Administrative User"
        sanity_var ADMIN_PASS "Administrative Password"

        instanceid=nc$(dd if=/dev/urandom bs=1 count=40 2>/dev/null | sha1sum | fold -w 10 | head -n 1)

        cat <<EOF | silent tee "${CONFIG_FILE}"
<?php
\$CONFIG = array (
  'instanceid' => '$instanceid',
  'datadirectory' => '${USERDATA_PATH}',

  "apps_paths" => array (
      0 => array (
              "path"     => "${NGINX_WEBROOT}/apps",
              "url"      => "/apps",
              "writable" => false,
      ),
      1 => array (
              "path"     => "${APP_PATH}",
              "url"      => "/custom-apps",
              "writable" => true,
      ),
  ),
);
?>
EOF

        print_warn "Starting automatic configuration for Nextcloud version ${NEXTCLOUD_VERSION}"
        #chown -R "${NGINX_USER}":"${NGINX_GROUP}" "${NGINX_WEBROOT}"
        sudo -u "${NGINX_USER}" touch "${NGINX_WEBROOT}"/config/CAN_INSTALL
        silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT}"/occ maintenance:install \
            -n -q \
            --admin-user "${ADMIN_USER}" \
            --admin-pass "${ADMIN_PASS}" \
            --data-dir="${USERDATA_PATH}" \
            ${install_options}
        rm -rf "${NGINX_WEBROOT}"/config/CAN_INSTALL
        print_warn "Automatic configuration finished."
        #chown -R "${NGINX_USER}":"${NGINX_GROUP}" "${NGINX_WEBROOT}"/
        # Enable/disable apps. Note that this must be done after the Nextcloud setup.
        silent sudo -u "${NGINX_USER}" php "${NGINX_WEBROOT}"/occ app:disable firstrunwizard
        echo "${NEXTCLOUD_VERSION} first installed on $(TZ=${TIMEZONE} date +'%Y-%m-%d %H:%M:%S %Z')" | silent tee -a "${USERDATA_PATH%/}"/.version
    fi
}

version_greater() {
    ver1_main=$(echo "$1" | grep -o '^[0-9.]*')
    ver2_main=$(echo "$2" | grep -o '^[0-9.]*')

    ver1_pre=${1#"$ver1_main"}
    ver2_pre=${2#"$ver2_main"}

    if [ "$ver1_main" != "$ver2_main" ]; then
        [[ "$(printf '%s\n' "$ver1_main" "$ver2_main" | sort -V | head -n 1)" != "$ver1_main" ]]
    else
        if [ -z "$ver1_pre" ] && [ -n "$ver2_pre" ]; then
            return 0
        elif [ -n "$ver1_pre" ] && [ -z "$ver2_pre" ]; then
            return 1
        else
            [[ "$(printf '%s\n' "$ver1_pre" "$ver2_pre" | sort -V | head -n 1)" != "$ver1_pre" ]]
        fi
    fi
}
